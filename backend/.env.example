# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./cinemalist.db

# ── TMDb API ──────────────────────────────────────────────
# Register free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE=https://image.tmdb.org/t/p

# ── App settings ──────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_string_at_least_32_chars
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── LLM (Phase 5 – leave empty for now) ───────────────────
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_PROXY_URL=https://api.openai.com/v1

# ── Media storage ─────────────────────────────────────────
# Folder where poster images are cached locally
MEDIA_DIR=./media
